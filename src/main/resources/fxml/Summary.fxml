<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.final_project.extension.SummaryController">

    <top>
        <HBox styleClass="navbar" spacing="24">
            <padding>
                <Insets top="16" bottom="16" left="32" right="32"/>
            </padding>
            <Label fx:id="navLogo" text="36BANK" styleClass="nav-logo" onMouseClicked="#handleNavHome"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="24" styleClass="nav-links">
                <Button text="News" styleClass="nav-btn" onAction="#handleNavNews" />
                <Button text="Branches" styleClass="nav-btn" onAction="#handleNavBranches"/>
                <Button text="Profile" styleClass="nav-btn" onAction="#handleNavProfile"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <StackPane alignment="CENTER">
            <padding>
                <Insets top="32" bottom="32" left="32" right="32"/>
            </padding>

            <VBox maxWidth="1100.0" spacing="24" alignment="TOP_CENTER">
                <Label text="Financial Summary" styleClass="text-title-large" maxWidth="Infinity" alignment="TOP_LEFT"/>

                <HBox spacing="24" alignment="CENTER">

                    <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="12" prefWidth="500.0">
                        <padding>
                            <Insets top="24" bottom="24" left="24" right="24"/>
                        </padding>
                        <Label text="Income vs Expenses (Days)" styleClass="text-desc-medium"/>
                        <BarChart fx:id="daysChart" prefHeight="350.0" animated="false">
                            <xAxis>
                                <CategoryAxis side="BOTTOM" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis side="LEFT" />
                            </yAxis>
                        </BarChart>
                    </VBox>

                    <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="12" prefWidth="500.0">
                        <padding>
                            <Insets top="24" bottom="24" left="24" right="24"/>
                        </padding>
                        <Label text="Income vs Expenses (Months)" styleClass="text-desc-medium"/>
                        <BarChart fx:id="monthsChart" prefHeight="350.0" animated="false">
                            <xAxis>
                                <CategoryAxis side="BOTTOM" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis side="LEFT" />
                            </yAxis>
                        </BarChart>
                    </VBox>

                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>