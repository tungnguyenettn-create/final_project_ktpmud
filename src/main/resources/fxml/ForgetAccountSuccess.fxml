<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.final_project.forget_account.ForgetAccountSuccessController">

    <top>
        <HBox styleClass="navbar" spacing="24">
            <padding>
                <Insets top="16" bottom="16" left="32" right="32"/>
            </padding>
            <Label text="36BANK" styleClass="nav-logo"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="24" styleClass="nav-links">
                <Button text="Home" styleClass="nav-btn" onAction="#handleNavHome"/>
                <Button text="News" styleClass="nav-btn" onAction="#handleNavNews"/>
                <Button text="Branches" styleClass="nav-btn" onAction="#handleNavBranches"/>
                <Button text="Profile" styleClass="nav-btn" onAction="#handleNavProfile"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <StackPane alignment="CENTER">
            <padding>
                <Insets top="32" bottom="32" left="32" right="32"/>
            </padding>

            <VBox styleClass="card" maxWidth="400.0" spacing="16" alignment="TOP_LEFT">

                <Label text="FORGET ACCOUNT" alignment="CENTER" maxWidth="Infinity" style="-fx-font-size: 36;">
                    <VBox.margin>
                        <Insets bottom="12"/>
                    </VBox.margin>
                </Label>

                <Label text="Account Related" style="-fx-font-weight: bold; -fx-font-size: 14;"/>

                <ScrollPane fitToWidth="true" prefHeight="120.0"
                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-hbar-policy: NEVER;">
                    <content>
                        <VBox fx:id="accountContainer" spacing="8" style="-fx-background-color: #f4f4f4; -fx-background-radius: 8;">
                            <padding>
                                <Insets top="16" bottom="16" left="16" right="16"/>
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
                <Region VBox.vgrow="ALWAYS"></Region>
                <Button text="OK" styleClass="btn-primary" maxWidth="Infinity" onAction="#handleOkAction">
                    <VBox.margin>
                        <Insets top="8"/>
                    </VBox.margin>
                </Button>

            </VBox>
        </StackPane>
    </center>

</BorderPane>