<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.final_project.login_page.LoginPageController"
           prefWidth="1280.0" prefHeight="800.0"
           style="-fx-background-color: linear-gradient(to bottom, #ffffff 0%, #eaeaf0 40%, #dcdfe0 100%);">

    <Region style="-fx-background-image: url('https://i.pinimg.com/1200x/ee/26/fe/ee26fe3a94febbbac011ed6ee677ba7f.jpg');
                   -fx-background-size: cover;
                   -fx-background-position: center center;
                   -fx-background-repeat: no-repeat;" />

    <Label text="IMAGE SOURCE: Words Bubble Up Like Soda Pop - Kyōhei Ishiguro"
           StackPane.alignment="BOTTOM_LEFT"
           style="-fx-font-size: 10px; -fx-font-weight: 300; -fx-text-fill: #31456e; -fx-opacity: 0.3; -fx-padding: 0 0 10 15;"/>

    <BorderPane prefWidth="1150.0" prefHeight="720.0"
                style="-fx-background-color: rgba(255, 255, 255, 0.6); -fx-background-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 20, 0, 0, 10);">

        <top>
            <HBox styleClass="navbar" spacing="32" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="20" bottom="20" left="48" right="48"/>
                </padding>
                <Label text="36BANK" styleClass="nav-logo" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #31456e;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="28" styleClass="nav-links" alignment="CENTER_RIGHT">
                    <Button text="Home" styleClass="nav-btn" onAction="#handleNavHome"/>
                    <Button text="News" styleClass="nav-btn" onAction="#handleNavNews"/>
                    <Button text="Branches" styleClass="nav-btn" onAction="#handleNavBranches"/>
                    <Button text="Profile" styleClass="nav-btn" onAction="#handleNavProfile"/>
                </HBox>
            </HBox>
        </top>

        <center>
            <StackPane alignment="CENTER">
                <padding>
                    <Insets top="10" bottom="40" left="48" right="48"/>
                </padding>

                <VBox maxWidth="360.0"  maxHeight="200" spacing="20" alignment="TOP_LEFT"
                      styleClass="card">

                    <Label text="LOGIN" alignment="CENTER" maxWidth="Infinity"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #31456e;"/>

                    <VBox spacing="6">
                        <Label text="Account"  />
                        <TextField fx:id="usernameField" promptText="Enter account"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Password"  />
                        <PasswordField fx:id="passwordField" promptText="Enter password"/>
                    </VBox>
                    <VBox alignment="BOTTOM_RIGHT">
                        <Hyperlink text="Forget Account" onAction="#handleForgetAccount"/>
                        <Hyperlink text="Forget Password" onAction="#handleForgetPassword"/>
                    </VBox>
                    <Button fx:id="loginBtn" text="LOGIN" styleClass="btn-primary" maxWidth="Infinity" onAction="#handleLoginSubmit">
                        <VBox.margin>
                            <Insets top="10"/>
                        </VBox.margin>
                    </Button>

                </VBox>
            </StackPane>
        </center>
    </BorderPane>
</StackPane>