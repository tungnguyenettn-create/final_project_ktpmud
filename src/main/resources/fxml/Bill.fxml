<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.final_project.extension.BillController">

    <top>
        <HBox styleClass="navbar" spacing="24">
            <padding>
                <Insets top="16" bottom="16" left="32" right="32"/>
            </padding>
            <Label text="36Bank" styleClass="nav-logo"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="24" styleClass="nav-links">
                <Button text="News" styleClass="nav-btn"/>
                <Button text="Branches" styleClass="nav-btn"/>
                <Button text="Profile" styleClass="nav-btn"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <StackPane alignment="CENTER">
            <padding>
                <Insets top="32" bottom="32" left="32" right="32"/>
            </padding>

            <VBox maxWidth="600.0" spacing="24" alignment="TOP_CENTER">
                <Label text="Bills Transfer" styleClass="text-title-large" maxWidth="Infinity" alignment="TOP_LEFT"/>

                <VBox styleClass="card" spacing="20" alignment="TOP_LEFT">
                    <padding>
                        <Insets top="24" bottom="24" left="24" right="24"/>
                    </padding>

                    <VBox spacing="8">
                        <Label text="Select Provider" styleClass="text-desc-medium"/>
                        <ComboBox fx:id="providerSelect" maxWidth="Infinity" prefHeight="40.0"
                                  styleClass="combo-box-white"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="Amount" styleClass="text-desc-medium"/>
                        <TextField fx:id="amountField" promptText="Enter amount" prefHeight="40.0"/>
                    </VBox>

                    <Button text="Transfer" styleClass="btn-primary" maxWidth="Infinity" prefHeight="44.0" onAction="#handleTransfer">
                        <VBox.margin>
                            <Insets top="8"/>
                        </VBox.margin>
                    </Button>
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>