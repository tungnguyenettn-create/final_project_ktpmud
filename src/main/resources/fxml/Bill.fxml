<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.final_project.extension.BillController"
           prefWidth="1280.0" prefHeight="800.0"
           style="-fx-background-color: linear-gradient(to bottom, #ffffff 0%, #eaeaf0 40%, #dcdfe0 100%);">

    <Region style="-fx-background-image: url('https://i.pinimg.com/1200x/ee/26/fe/ee26fe3a94febbbac011ed6ee677ba7f.jpg');
                   -fx-background-size: cover;
                   -fx-background-position: center center;
                   -fx-background-repeat: no-repeat;" />

    <Label text="IMAGE SOURCE: Words Bubble Up Like Soda Pop - Kyōhei Ishiguro"
           StackPane.alignment="BOTTOM_LEFT"
           style="-fx-font-size: 10px; -fx-font-weight: 300; -fx-text-fill: #31456e; -fx-opacity: 0.3; -fx-padding: 0 0 10 15;"/>

    <BorderPane prefWidth="1150.0" prefHeight="720.0"
                style="-fx-background-color: rgba(255, 255, 255, 0.6); -fx-background-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 20, 0, 0, 10);">
        <top>
            <HBox styleClass="navbar" spacing="24">
                <padding>
                    <Insets top="16" bottom="16" left="32" right="32"/>
                </padding>
                <Label text="36Bank" styleClass="nav-logo" onMouseClicked="#handleNavHome"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="24" styleClass="nav-links">
                    <Button text="News" styleClass="nav-btn"/>
                    <Button text="Branches" styleClass="nav-btn"/>
                    <Button text="Profile" styleClass="nav-btn"/>
                </HBox>
            </HBox>
        </top>

        <center>
            <StackPane alignment="CENTER">
                <padding>
                    <Insets top="32" bottom="32" left="32" right="32"/>
                </padding>

                <VBox maxWidth="600.0" spacing="24" alignment="TOP_CENTER">
                    <Label text="Bills Transfer" styleClass="text-title-large" maxWidth="Infinity" alignment="TOP_LEFT"/>

                    <VBox styleClass="card" spacing="20" alignment="TOP_LEFT">
                        <padding>
                            <Insets top="24" bottom="24" left="24" right="24"/>
                        </padding>

                        <VBox spacing="8">
                            <Label text="Select Provider" styleClass="text-desc-medium"/>
                            <ComboBox fx:id="providerSelect" maxWidth="Infinity" prefHeight="40.0"
                                      styleClass="combo-box-white"/>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="Amount" styleClass="text-desc-medium"/>
                            <TextField fx:id="amountField" promptText="Enter amount" prefHeight="40.0"/>
                        </VBox>

                        <Button text="Transfer" styleClass="btn-primary" maxWidth="Infinity" prefHeight="44.0" onAction="#handleTransfer">
                            <VBox.margin>
                                <Insets top="8"/>
                            </VBox.margin>
                        </Button>
                    </VBox>
                </VBox>
            </StackPane>
        </center>
    </BorderPane>
</StackPane>