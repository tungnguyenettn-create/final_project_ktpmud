<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.final_project.forget_account.ForgetAccountController"
>
    <top>
        <HBox styleClass="navbar" spacing="24">
            <padding>
                <Insets top="16" bottom="16" left="32" right="32"/>
            </padding>
            <Label text="36BANK" styleClass="nav-logo" onMouseClicked="#handleNavHome"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="24" styleClass="nav-links">
                <Button text="Home" styleClass="nav-btn" onAction="#handleNavHome"/>
                <Button text="News" styleClass="nav-btn" onAction="#handleNavNews"/>
                <Button text="Branches" styleClass="nav-btn" onAction="#handleNavBranches"/>
                <Button text="Profile" styleClass="nav-btn" onAction="#handleNavProfile"/>
            </HBox>
        </HBox>

    </top>

    <center>
        <StackPane alignment="CENTER">
            <padding>
                <Insets top="32" bottom="32" left="32" right="32">
                </Insets>
            </padding>
            <VBox styleClass="card" maxWidth="400.0" spacing="16" alignment="TOP_LEFT">
                <Label text="FORGET ACCOUNT" alignment="CENTER" maxWidth="Infinity"
                       style="-fx-font-size: 36; -fx-margin-bottom: 24;">
                </Label>

                <VBox spacing="8">
                    <Label text="Phone Number" />
                    <TextField fx:id="phoneNumberField" promptText="Enter phone number"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="Identity Card" />
                    <TextField fx:id="identityField" promptText="Enter identity card number"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"></Region>

                <Button text="GET ACCOUNT" styleClass="btn-primary" maxWidth="Infinity" onAction="#handleGetAccount">
                    <VBox.margin>
                        <Insets top="8"/>
                    </VBox.margin>
                </Button>


            </VBox>
        </StackPane>
    </center>

</BorderPane>